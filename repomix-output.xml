  (
    {
      label,
      error,
      description,
      className = "",
      id: propId,
      required,
      ...props
    },
    ref,
  ) => {
    // تولید خودکار ID برای ارتباط بین label و input
    const generatedId = useId();
    const id = propId || generatedId;

    // تولید IDهای منحصر به فرد برای aria-describedby
    const errorId = error ? `${id}-error` : undefined;
